<%- include('ost/header', { title: 'Вход' }) %>

    <div class="row justify-content-center">

        <div class="container py-5">

            <!-- Слайдер -->
            <div id="mainCarousel" class="carousel slide mb-5 shadow rounded overflow-hidden" data-bs-ride="carousel">

                <div class="carousel-indicators">
                    <button type="button" data-bs-target="#mainCarousel" data-bs-slide-to="0" class="active"></button>
                    <button type="button" data-bs-target="#mainCarousel" data-bs-slide-to="1"></button>
                    <button type="button" data-bs-target="#mainCarousel" data-bs-slide-to="2"></button>
                </div>

                <div class="carousel-inner">

                    <div class="carousel-item active">
                        <img src="1.jpg" class="d-block w-100" style="height:450px; object-fit:cover;"
                            alt="">
                        <div class="carousel-caption d-none d-md-block" style="background-color: rgba(0, 0, 0, 0.445); border-radius: 25%;">
                            <h2>Управляйте своими задачами</h2>
                            <p>Создавайте задачи и следите за их выполнением.</p>
                        </div>
                    </div>

                    <div class="carousel-item">
                        <img src="2.png" class="d-block w-100" style="height:450px; object-fit:cover;"
                            alt="">
                        <div class="carousel-caption d-none d-md-block" style="background-color: rgba(0, 0, 0, 0.445); border-radius: 25%;">
                            <h2>Контролируйте сроки</h2>
                            <p>Добавляйте дедлайны и устанавливайте приоритет.</p>
                        </div>
                    </div>

                    <div class="carousel-item">
                        <img src="3.jpg" class="d-block w-100" style="height:450px; object-fit:cover;"
                            alt="">
                        <div class="carousel-caption d-none d-md-block" style="background-color: rgba(0, 0, 0, 0.445); border-radius: 25%;">
                            <h2>Работайте эффективнее</h2>
                            <p>Планируйте день и выполняйте задачи вовремя.</p>
                        </div>
                    </div>

                </div>

                <button class="carousel-control-prev" type="button" data-bs-target="#mainCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>

                <button class="carousel-control-next" type="button" data-bs-target="#mainCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>

            </div>

            <!-- Описание -->
            <div class="row justify-content-center">

                <div class="col-lg-8">

                    <div class="card border-1 shadow-sm">

                        <div class="card-body text-center p-5">

                            <h1 class="display-5 fw-bold mb-4">
                                Добро пожаловать в TaskFlow
                            </h1>

                            <p class="lead mb-4">
                                <strong>TaskFlow</strong> — это удобное веб-приложение для управления личными задачами.
                                Создавайте новые задачи, устанавливайте приоритеты, контролируйте сроки выполнения,
                                оставляйте комментарии и отслеживайте прогресс в одном месте.
                            </p>





                            <% if (!userId && !isAdmin) { %>
                                <p class="text-muted mb-5">
                                    Зарегистрируйтесь, чтобы начать пользоваться системой,
                                    или войдите в уже существующий аккаунт.
                                </p>

                                <div class="d-flex justify-content-center gap-3">

                                    <a href="/login" class="btn btn-primary btn-lg px-4">
                                        Войти
                                    </a>

                                    <a href="/register" class="btn btn-outline-primary btn-lg px-4">
                                        Зарегистрироваться
                                    </a>

                                </div>

                                <% } %>

                                    <% if (userId) { %>

                                        <div class="d-flex justify-content-center gap-3">
                                            <a href="/create" class="btn btn-primary btn-lg px-4">
                                                Создать задачу
                                            </a>
                                        </div>
                                        <% } %>


                        </div>

                    </div>

                </div>

            </div>

        </div>
    </div>

    <%- include('ost/footer') %>