<%- include('ost/header', { title: 'Вход' }) %>

<% if (tasks.length === 0) { %>

    <div class="alert alert-info text-center">
        Задач нет
    </div>

<% } else { %>

    <% tasks.forEach(task=> { %>

        <div class="card mb-3">
            <div class="card-body">

                <div class="d-flex justify-content-between align-items-start">

                    <h5 class="card-title mb-2"><%= task.title %></h5>

                    <div>
                        <a href="/tasks/<%= task.id %>" class="btn btn-sm btn-outline-primary">
                            👁
                        </a>

                        <a href="/tasks/edit/<%= task.id %>" class="btn btn-sm btn-outline-success">
                            ✏
                        </a>

                        <form action="/tasks/delete/<%= task.id %>" method="POST" style="display:inline">
                            <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Удалить задачу?')">
                                🗑
                            </button>
                        </form>
                    </div>

                </div>

                <div class="mb-2">
                    <span class="badge bg-danger"><%= task.priority %></span>
                    <span class="badge bg-warning text-dark"><%= task.status %></span>
                </div>

                <p class="card-text text-muted mb-0">
                    Дедлайн: <%= task.deadline %>
                </p>

            </div>
        </div>

    <% }) %>

<% } %>

<%- include('ost/footer') %>